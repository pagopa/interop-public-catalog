---
// !! Careful: CSS order of imports matters
import "../styles/fonts.css";
import "bootstrap-italia/dist/css/bootstrap-italia.min.css";
import "../styles/onetrust.css";
import "../styles/styles.css";

import Header from "../components/shared/Header/Header.astro";
import Footer from "../components/shared/Footer.astro";
import { getLangFromUrl } from "../i18n/utils.i18n";
import { clientEnvConfig } from "../config/config";
import BackToTopButton from "../components/shared/BackToTopButton.astro";
import type { Seo } from "../types/seo";

type Props = {
  seo: Seo;
};

const { seo } = Astro.props as Props;

const currentLocale = getLangFromUrl(Astro.url.pathname);
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <script
      is:inline
      set:html={`window.env = ${JSON.stringify(clientEnvConfig).replace(/</g, "\\u003c")}`}
    />
    {
      import.meta.env.PROD && (
        <script
          is:inline
          src="https://cdn.cookielaw.org/scripttemplates/otSDKStub.js"
          type="text/javascript"
          charset="UTF-8"
          data-domain-script={clientEnvConfig.onetrustDomainScriptId}
          data-language={currentLocale}
        />
      )
    }
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta name="generator" content={Astro.generator} />

    <title>{seo.MetaTitle}</title>
    <meta name="description" content={seo.MetaDescription} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.MetaTitle} />
    <meta name="twitter:description" content={seo.MetaDescription} />
    <meta name="twitter:image" content={seo.TwitterImage.url} />
    <meta
      property="og:locale"
      content={currentLocale === "it" ? "it_IT" : "en_US"}
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.MetaTitle} />
    <meta property="og:description" content={seo.MetaDescription} />
    <meta property="og:url" content={Astro.url.pathname} />
    <meta property="og:site_name" content={seo.MetaTitle} />
    <meta property="og:image" content={seo.OpenGraphImage.url} />
    <link rel="canonical" href={Astro.url.pathname} />
  </head>
  <body>
    <Header />
    <BackToTopButton />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import { initBootstrapItaliaComponents } from "../config/bootstrap-italia";
  import type { ClientEnvConfig } from "../config/config";
  import { mixpanelService } from "../services/mixpanel.services";

  /**
   * Initializes Bootstrap Italia components that require JavaScript to work.
   * E.g.: modals, dropdowns, tooltips, etc.
   */
  initBootstrapItaliaComponents();
  mixpanelService.init({
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    projectId: ((window as any).env as ClientEnvConfig).mixpanelProjectId,
  });
  mixpanelService.bindTrackingExternalLinkVisitEvent();
  mixpanelService.bindTrackingTooltipOpenEvent();
</script>
