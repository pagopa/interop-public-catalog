---
import type { EServiceAttributes } from "pagopa-interop-public-models";
import { useEServiceDetailsTranslations } from "../../../i18n/eservice-details.i18n.js";
import { getLangFromUrl } from "../../../i18n/utils.i18n";
import { PopoverIcon } from "../../shared/PopoverIcon.js";
import type { RequirementsSection } from "../../../types/pages/eserviceDetails";

const currentLocale = getLangFromUrl(Astro.url.pathname);
const t = useEServiceDetailsTranslations(currentLocale);

interface Props {
  groupIndex: number;
  attributeType: keyof EServiceAttributes;
  attributes: EServiceAttributes[keyof EServiceAttributes][number];
  strapiContent: RequirementsSection;
}

const { groupIndex, attributeType, attributes, strapiContent } = Astro.props;

function getTitle(attributeType: keyof EServiceAttributes) {
  if (attributeType === "certified") {
    return strapiContent.CertifiedAttributeLabel;
  }

  if (attributeType === "verified") {
    return strapiContent.VerifiedAttributeLabel;
  }

  // attributeType === 'declared'
  return strapiContent.DeclaredAttributeLabel;
}

function getTooltip(attributeType: keyof EServiceAttributes) {
  if (attributeType === "certified") {
    return {
      title: strapiContent.CertifiedAttributeLabel,
      content: strapiContent.CertifiedAttributeTooltip,
    };
  }

  if (attributeType === "verified") {
    return {
      title: strapiContent.VerifiedAttributeLabel,
      content: strapiContent.VerifiedAttributeTooltip,
    };
  }

  // attributeType === 'declared'
  return {
    title: strapiContent.DeclaredAttributeLabel,
    content: strapiContent.DeclaredAttributeTooltip,
  };
}

function getDescription(attributeType: keyof EServiceAttributes) {
  if (attributeType === "certified") {
    return strapiContent.CertifiedAttributeDescription;
  }

  if (attributeType === "verified") {
    return strapiContent.VerifiedAttributeDescription;
  }

  // attributeType === 'declared'
  return strapiContent.DeclaredAttributeDescription;
}

const tooltip = getTooltip(attributeType);
---

<div class="p-3 rounded-3 bg-primary-c0">
  <h6 class="me-2">
    {getTitle(attributeType)}
    <PopoverIcon
      title={tooltip.title}
      content={tooltip.content}
      iconName="it-info-circle"
    />
  </h6>
  <p>
    {getDescription(attributeType)}
  </p>
  <div class="accordion border-0" id={`accordionGroup${groupIndex}`}>
    {
      attributes.map(({ description, name }, index) => (
        <>
          <div class="accordion-item rounded-2">
            <h2 class="accordion-header" id={`heading${groupIndex}${index}`}>
              <button
                class="accordion-button border-0 collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target={`#collapse${groupIndex}${index}`}
                aria-expanded="false"
                aria-controls={`collapse${groupIndex}${index}`}
              >
                {name}
              </button>
            </h2>
            <div
              id={`collapse${groupIndex}${index}`}
              class="accordion-collapse collapse"
              data-bs-parent={`#accordionGroup${groupIndex}`}
              role="region"
              aria-labelledby={`heading${groupIndex}${index}`}
            >
              <div class="accordion-body">{description}</div>
            </div>
          </div>
          {index < attributes.length - 1 && (
            <p class="my-2">{t("attributes_section.group.or")}</p>
          )}
        </>
      ))
    }
  </div>
</div>
