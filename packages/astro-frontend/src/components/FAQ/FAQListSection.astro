---
import { renderRichTextStrapiNodes } from "../../utils/rich-text-strapi-renderer.js";
import { Section } from "../shared/Section";
import type { SectionItem } from "../../types/pages";
interface Props {
  sectionId: string;
  title: string;
  faqs: Array<SectionItem>;
}

const { sectionId, title, faqs } = Astro.props;
---

<Section title={title} className="pb-0">
  <div class="row">
    <div class="col-12 col-md-8">
      <div class="accordion" id={`accordionGroup${sectionId}`}>
        {
          faqs.map(({ FAQQuestion, FAQAnswer, FAQId }) => (
            <>
              <div class="accordion-item bg-transparent">
                <h3 class="accordion-header" id={`heading${sectionId}${FAQId}`}>
                  <button
                    class="accordion-button collapsed py-3"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target={`#collapse${sectionId}${FAQId}`}
                    aria-expanded="false"
                    aria-controls={`collapse${sectionId}${FAQId}`}
                  >
                    {FAQQuestion}
                  </button>
                </h3>
                <div
                  id={`collapse${sectionId}${FAQId}`}
                  data-mp-faq-id={FAQId}
                  data-mp-faq-title={FAQQuestion}
                  class="accordion-collapse collapse"
                  data-bs-parent={`#accordionGroup${sectionId}`}
                  role="region"
                  aria-labelledby={`heading${sectionId}${FAQId}`}
                >
                  <div class="accordion-body">
                    <div set:html={renderRichTextStrapiNodes(FAQAnswer)} />
                  </div>
                </div>
              </div>
            </>
          ))
        }
      </div>
    </div>
  </div>
</Section>
