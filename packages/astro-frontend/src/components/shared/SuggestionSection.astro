---
import { BootstrapItaliaIcon } from "./BootstrapItaliaIcon";
import { Section } from "./Section";
import type { HowToSection } from "../../types/general";

type Props = {
  strapiContents: HowToSection;
};

const { strapiContents } = Astro.props as Props;
---

<div class="pb-4" id="suggestion-section">
  <Section
    style={{ maxWidth: "1076px" }}
    className="mx-auto"
    title={strapiContents.Title}
    titleClass="text-white"
  >
    <div class="d-flex flex-column flex-lg-row gap-4">
      {
        strapiContents.HowTo.map((suggestion) => (
          <article class="bg-white rounded shadow-sm p-5" style="flex: 1;">
            <img
              style="fill: var(--bs-primary);"
              src={suggestion.Illustration.url}
              class="mb-4 color-primary"
              alt={suggestion.Illustration.alternativeText}
              loading="lazy"
              role="presentation"
              width="96"
              height="96"
            />
            <h3 class="h4 mb-3">{suggestion.Title}</h3>
            <p class="it-card-text text-secondary mb-3">
              {suggestion.Description}
            </p>
            <footer>
              <a
                href={suggestion.LinkURL}
                class="btn btn-primary btn-icon"
                data-mp-external-link-id={suggestion.MixpanelExternalLinkId}
                data-mp-external-link-description={
                  suggestion.MixpanelExternalLinkDescription
                }
                {...(!suggestion.IsLinkInternal
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
              >
                {suggestion.LinkLabel}
                {!suggestion.IsLinkInternal && (
                  <BootstrapItaliaIcon
                    className="ms-2"
                    name="it-external-link"
                    color="white"
                  />
                )}
              </a>
            </footer>
          </article>
        ))
      }
    </div>
  </Section>
</div>

<style>
  #suggestion-section {
    background: linear-gradient(to bottom, var(--bs-primary), #004d99 100%);
  }
</style>
