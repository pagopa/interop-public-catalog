---
import type { HowItWorks } from "../../types/pages";
import { BootstrapItaliaIcon } from "../shared/BootstrapItaliaIcon";
import { Section } from "../shared/Section";

interface Props {
  content: HowItWorks;
}

const { content } = Astro.props;
---

<Section className="section-muted py-5" title={content.Title}>
  <div class="list-group list-group-horizontal-md">
    {
      content.HowItWorksItem.map((item, index) => (
        <>
          <div class="flex-fill list-group-item bg-transparent border-0 p-0">
            {/* Card */}
            <article class="it-card bg-transparent d-flex flex-column h-100">
              <div class="it-card-banner-icon-wrapper mb-2">
                <img
                  src={item.Illustration.url}
                  alt={item.Illustration.alternativeText}
                  role="presentation"
                  width="96"
                  height="96"
                />
              </div>
              {/* Card Body */}
              <h3 class="it-card-title h5 ps-0">{item.Title}</h3>
              <div class="it-card-body mb-2 ps-0">
                <p class="it-card-text">{item.Description}</p>
              </div>
              {/* Card Footer */}
              <footer class="it-card-related it-card-footer mt-auto ms-0">
                <div class="it-card-taxonomy">
                  <a
                    href={item.LinkURL}
                    data-mp-external-link-id={item.MixpanelExternalLinkId}
                    data-mp-external-link-description={
                      item.MixpanelExternalLinkDescription
                    }
                    data-mp-good-practice-catalog-referral={
                      item.MixpanelGoodpracticeCatalogReferral
                    }
                    {...(!item.IsLinkInternal
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {})}
                    class="it-card-category it-card-link text-uppercase text-primary"
                  >
                    {item.LinkLabel}
                    <BootstrapItaliaIcon
                      name="it-arrow-right"
                      size="sm"
                      color="primary"
                    />
                  </a>
                </div>
              </footer>
            </article>
          </div>
          {index < content.HowItWorksItem.length - 1 && (
            <>
              {/* Horizontal separator for mobile/tablet */}
              <hr class="d-block d-md-none mb-4 mt-0 border-2 border-primary" />
              {/* Vertical separator for large screens */}
              <div class="vr d-none d-md-block mx-4 text-primary" />
            </>
          )}
        </>
      ))
    }
  </div>
</Section>
