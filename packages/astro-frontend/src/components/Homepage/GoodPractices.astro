function getOrganizationTypeHref(macroCategory: MacroCategory) {
  // const macroCategoryId = getMacroCategoryIdByKey(macroCategory);
  const macroCategoryId = macroCategory.MacroCategoryId;

  const urlSearchParams = new URLSearchParams({ macroCategoryId }).toString();
  return `${getLocalizedRoute(currentLocale, "GOOD_PRACTICES_CATALOG")}?${urlSearchParams}`;
}

