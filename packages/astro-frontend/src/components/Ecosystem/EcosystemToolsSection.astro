---
import type { Tools } from "../../types/pages";
import { BootstrapItaliaIcon } from "../shared/BootstrapItaliaIcon";
import { Section } from "../shared/Section";

interface Props {
  toolsSection: Tools;
}

const { toolsSection } = Astro.props;
---

<Section className="position-relative pb-0 pb-md-5 pt-5 mb-md-4">
  {/* Background - Mobile */}
  <div
    aria-hidden="true"
    style="inset:0;z-index:-1;"
    class="position-absolute d-md-none bg-primary-c0"
  >
  </div>

  <div class="position-relative py-5 px-md-5">
    {/* Background - Desktop */}
    <div
      style="inset:0;z-index:-1;"
      class="bg-primary-c0 rounded-5 border border-secondary position-absolute d-none d-md-block"
    >
    </div>

    <h2 class="h3 mb-4">{toolsSection.Title}</h2>
    <p class="mb-4 text-secondary">
      {toolsSection.Subtitle}
    </p>
    <div class="d-flex flex-column flex-lg-row gap-4 gap-lg-3">
      {
        toolsSection.SingleTool.map((tool) => (
          <article class="it-card rounded shadow-sm align-items-start p-1">
            <h3 class="h5 it-card-title text-primary">{tool.Title}</h3>
            <div class="it-card-body text-start">
              <p class="it-card-text">{tool.Subtitle}</p>
              <p class="it-card-text fw-bold mb-1">{toolsSection.UsageLabel}</p>
              <p class="it-card-text">{tool.Description}</p>
            </div>
            <footer class="it-card-related it-card-footer mt-auto">
              <div class="it-card-taxonomy">
                <a
                  data-mp-external-link-id={tool.MixpanelExternalLinkId}
                  data-mp-external-link-description={
                    tool.MixpanelExternalLinkDescription
                  }
                  href={tool.LinkURL}
                  target="_blank"
                  rel="noreferrer noopener"
                  class="it-card-link text-primary text-decoration-none fw-semibold"
                >
                  {toolsSection.LinkLabel}
                  <BootstrapItaliaIcon
                    className="ms-1 mb-1"
                    name="it-external-link"
                    size="sm"
                    color="primary"
                  />
                </a>
              </div>
            </footer>
          </article>
        ))
      }
    </div>
  </div>
</Section>
