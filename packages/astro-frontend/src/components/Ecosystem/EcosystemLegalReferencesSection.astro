---
// import { useEcosystemTranslations } from "../../i18n/ecosystem.i18n";
// import { getLangFromUrl, getLocalizedRoute } from "../../i18n/utils.i18n";
import type { Legislation } from "../../types/pages";
import { BootstrapItaliaIcon } from "../shared/BootstrapItaliaIcon";
import { Section } from "../shared/Section";

// const currentLocale = getLangFromUrl(Astro.url.pathname);
// const t = useEcosystemTranslations(currentLocale);
// const legislationLink = getLocalizedRoute(currentLocale, "LEGISLATION");

interface Props {
  legislation: Legislation;
}

const { legislation } = Astro.props;

// TODO remove strings and comments
// t("ecosystem_legal_references.title")
// t("ecosystem_legal_references.subtitle")
// legislationLink
// t("ecosystem_legal_references.button")
---

<Section
  className="py-5"
  style={{ backgroundColor: "#EBECED" }}
  title={legislation.Title}
>
  <div class="row">
    <p class="col-12 col-md-9 text-secondary">
      {legislation.Subtitle}
    </p>
    <div
      class="col-12 col-md-3 d-flex align-items-start justify-content-md-end mt-2 mt-md-0"
    >
      <a href={legislation.LinkURL}>
        <button class="btn btn-outline-primary btn-icon" type="button">
          {legislation.LinkLabel}
          <BootstrapItaliaIcon
            name="it-arrow-right"
            size="sm"
            color="primary"
            padded
          />
        </button>
      </a>
    </div>
  </div>
</Section>
