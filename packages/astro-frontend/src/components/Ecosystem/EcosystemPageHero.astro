import type { Feature } from "../../types/pages";
import PageHero from "../shared/PageHero.astro";

// const currentLocale = getLangFromUrl(Astro.url.pathname);
// const t = useEcosystemTranslations(currentLocale);

interface Props {
  title: string;
  description: string;
  features: Feature[];
  infographic: StrapiImage;
}

const { title, description, features, infographic } = Astro.props;

// const ECOSYSTEM_CHARACTERISTICS = [
