---

<PageHero
  title={title}
  breadcrumbItems={[
    { routeKey: "HOME" },
    { routeKey: "ECOSYSTEM", current: true },
  ]}
>
  <div slot="bottom-hero">
    <div class="row">
      <div class="col-12 col-lg-7">
        <p>{description}</p>

        <div class="row row-cols-lg-2 row-cols-1 mt-5 pt-4">
          {
            features.map((feature) => (
              <div class="pe-4 pb-4">
                <div class="border-start border-3 px-3">
                  <h2 style="font-size:1.25rem;" class="h6">
                    {feature.Title}
                  </h2>
                  <p
                    style="font-size:1rem;line-height:24px;"
                    class="text-secondary"
                  >
                    {feature.Description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="col-12 col-lg-5 position-relative d-none d-lg-block">
        <img
          src={infographic.url}
          style="right:0px;"
          class="position-absolute img-fluid bottom-0"
          width="416"
          height="544"
          alt={infographic.alternativeText}
        />
      </div>
    </div>
  </div>

  <div class="d-block d-lg-none" slot="bottom-hero">
    <img
      src={infographic.url}
      class="img-fluid"
      width="416"
      height="544"
      alt={infographic.alternativeText}
    />
  </div>
</PageHero>
