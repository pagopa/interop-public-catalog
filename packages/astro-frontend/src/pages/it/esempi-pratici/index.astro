---
import { Section } from "../../../components/shared/Section";
import { GoodPracticesCatalog } from "../../../components/GoodPracticesCatalog/GoodPracticesCatalog";
import { getLangFromUrl } from "../../../i18n/utils.i18n";
import Layout from "../../../layouts/Layout.astro";
import PageHero from "../../../components/shared/PageHero.astro";
import { parseAsString, createLoader } from "nuqs/server";
import { strapiService } from "../../../server/services";

const currentLocale = getLangFromUrl(Astro.url.pathname);

const { macroCategoryId } = createLoader({ macroCategoryId: parseAsString })(
  Astro.url.searchParams,
);

const strapiResponse =
  await strapiService.getGoodPracticesCatalogContent(currentLocale);

const strapiGeneralResponse =
  await strapiService.getGeneralContent(currentLocale);

if (!strapiResponse || !strapiGeneralResponse) {
  throw new Error("Could not fetch content from strapi");
}

const goodPracticesCatalogContent = strapiResponse.data;
const generalContents = strapiGeneralResponse.data;
---

<Layout seo={goodPracticesCatalogContent.Seo || generalContents.DefaultSeo}>
  <PageHero
    title={goodPracticesCatalogContent.Title}
    description={goodPracticesCatalogContent.Subtitle}
    breadcrumbItems={[
      {
        routeKey: "HOME",
      },
      {
        routeKey: "GOOD_PRACTICES_CATALOG",
        current: true,
      },
    ]}
  />

  <Section className="bg-muted">
    <GoodPracticesCatalog
      client:idle
      defaultMacroCategoryId={macroCategoryId}
      currentLocale={currentLocale}
      tenantMacrocategories={goodPracticesCatalogContent.Macrocategories}
    />
  </Section>
</Layout>
