---

<Layout seo={contents.Seo}>
  <EcosystemPageHero
    title={contents.Title}
    description={contents.Description}
    features={contents.Features}
    infographic={contents.Infographic}
  />
  <EcosystemToolsSection toolsSection={contents.Tools} />
  <EcosystemLegalReferencesSection legislation={contents.Legislation} />
  <EcosystemInteroperabilityLevelsSection
    interoperabilityLevels={contents.InteroperabilityLevels}
  />
  <RatingSection />
  <SuggestionsSection />
</Layout>
