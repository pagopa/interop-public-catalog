---
import Layout from "../../layouts/Layout.astro";
import EcosystemToolsSection from "../../components/Ecosystem/EcosystemToolsSection.astro";
import SuggestionSection from "../../components/shared/SuggestionSection.astro";
import RatingSection from "../../components/shared/RatingSection.astro";
import EcosystemPageHero from "../../components/Ecosystem/EcosystemPageHero.astro";
import EcosystemLegalReferencesSection from "../../components/Ecosystem/EcosystemLegalReferencesSection.astro";
import EcosystemInteroperabilityLevelsSection from "../../components/Ecosystem/EcosystemInteroperabilityLevelsSection.astro";
import { getLangFromUrl } from "../../i18n/utils.i18n";
import { strapiService } from "../../server/services";

const currentLocale = getLangFromUrl(Astro.url.pathname);
const strapiResponse =
  await strapiService.getInteroperabilityContent(currentLocale);

if (!strapiResponse) {
  throw new Error("Could not fetch content from strapi");
}

const contents = strapiResponse.data;
---

<Layout seo={contents.Seo}>
  <EcosystemPageHero
    title={contents.Title}
    description={contents.Description}
    features={contents.Features}
    infographic={contents.Infographic}
  />
  <EcosystemToolsSection toolsSection={contents.Tools} />
  <EcosystemLegalReferencesSection legislation={contents.Legislation} />
  <EcosystemInteroperabilityLevelsSection
    interoperabilityLevels={contents.InteroperabilityLevels}
  />
  <RatingSection />
  <SuggestionSection strapiContents={contents.HowToSection} />
</Layout>
