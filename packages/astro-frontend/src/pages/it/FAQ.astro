---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/shared/PageHero.astro";
import FAQListSection from "../../components/FAQ/FAQListSection.astro";
import RatingSection from "../../components/shared/RatingSection.astro";
import { strapiService } from "../../server/services";
import { getLangFromUrl } from "../../i18n/utils.i18n";

const currentLocale = getLangFromUrl(Astro.url.pathname);
const strapiResponse = await strapiService.getFaqContent(currentLocale);
const strapiGeneralResponse =
  await strapiService.getGeneralContent(currentLocale);

if (!strapiResponse || !strapiGeneralResponse) {
  throw new Error("Could not fetch content from strapi");
}

const faqContent = strapiResponse.data;
const generalContents = strapiGeneralResponse.data;
---

<Layout seo={faqContent.Seo || generalContents.DefaultSeo}>
  <PageHero
    title={faqContent.Title}
    description={faqContent.SubTitle}
    breadcrumbItems={[{ routeKey: "HOME" }, { routeKey: "FAQ", current: true }]}
  />

  <div class="bg-muted pb-5">
    {
      faqContent.FAQSection.map((faqSection) => (
        <FAQListSection
          sectionId={faqSection.FAQSectionId}
          title={faqSection.FAQSectionTitle}
          faqs={faqSection.FAQSectionItem}
        />
      ))
    }
  </div>

  <RatingSection />
</Layout>

<script>
  import { mixpanelService } from "../../services/mixpanel.services";
  mixpanelService.bindTrackingFaqOpenEvent();
</script>
