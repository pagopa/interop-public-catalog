---
import PageHero from "../../components/shared/PageHero.astro";
import PageIndexNav from "../../components/shared/PageIndexNav/PageIndexNav.astro";
import { Section } from "../../components/shared/Section";
import Layout from "../../layouts/Layout.astro";
import { renderRichTextStrapiNodes } from "../../utils/rich-text-strapi-renderer";
import { getLangFromUrl } from "../../i18n/utils.i18n";
// import { useUiTranslations } from "../../i18n/ui.i18n";
import { BootstrapItaliaIcon } from "../../components/shared/BootstrapItaliaIcon";
import { strapiService } from "../../server/services";

const currentLocale = getLangFromUrl(Astro.url.pathname);
// const tUi = useUiTranslations(currentLocale);
// TODO remove strings
// tUi("eservice_card.read_more")

const strapiResponse = await strapiService.getNormativaContent(currentLocale);

if (!strapiResponse) {
  throw new Error("Could not fetch Normativa content");
}

const contents = strapiResponse.data;
const body = contents.NormativaSection;

const sectionTitles = body.map((section) => ({
  id: section.documentId,
  label: section.NormativaSectionTitle,
}));
---

<Layout>
  <PageHero
    breadcrumbItems={[
      {
        routeKey: "HOME",
      },
      {
        routeKey: "LEGISLATION",
        current: true,
      },
    ]}
    title={contents.Title}
    description={contents.Subtitle}
  />

  <Section className="bg-muted">
    <div class="row">
      <div class="col-12 col-md-3">
        <PageIndexNav
          title={contents.IndexLabel}
          headings={sectionTitles}
          style="top: 1rem;"
          class="position-sticky"
        />
      </div>

      <div class="col-12 col-md-9">
        {
          body.map((section) => {
            return (
              <>
                <h2 class="h5 mb-4" id={section.documentId}>
                  {section.NormativaSectionTitle}
                </h2>
                {section.NormativaSectionItem.map((item) => {
                  return (
                    <>
                      <h3 class="h6 mb-1">{item.NormativaSectionItemTitle}</h3>
                      <Fragment
                        set:html={renderRichTextStrapiNodes(
                          item.NormativaSectionItemDescription,
                        )}
                      />
                      <a
                        href={item.NormativaSectionItemLink}
                        target="_blank"
                        class="it-card-link text-primary text-uppercase fw-semibold mb-5 d-inline-block"
                        rel="noreferrer"
                      >
                        {contents.LinkLabel}
                        <BootstrapItaliaIcon
                          aria-hidden="true"
                          name="it-arrow-right"
                          size="sm"
                          color="primary"
                          padded
                        />
                      </a>
                    </>
                  );
                })}
              </>
            );
          })
        }
      </div>
    </div>
  </Section>
</Layout>
